# OpenAI 自动注册系统 - 环境变量配置示例
# 复制此文件为 .env 并填写对应值

# ── Docker Compose（生产推荐） ────────────────────────────────
# 生产环境强烈建议修改；docker-compose.yml 会要求此值存在
WEBUI_ACCESS_PASSWORD=change_this_to_a_strong_password

# 外部反向代理网络名称（默认 1Panel）
PROXY_NETWORK=1panel-network

# 拉取的镜像地址（默认 latest）
CODEX_CONSOLE_IMAGE=ghcr.io/ifty-r/codex-console:latest

# 宿主机绑定地址 / 端口（推荐仅监听本机回环，再由 1Panel 反代到 127.0.0.1:1455）
WEBUI_BIND_IP=127.0.0.1
WEBUI_PUBLISH_PORT=1455

# 容器 CPU / 内存限制
WEBUI_CPUS=1.0
WEBUI_MEM_LIMIT=512m

# 容器共享内存，Chromium / Playwright 建议至少 1gb
WEBUI_SHM_SIZE=1gb

# 默认关闭 VNC / noVNC，排障时可配合 docker-compose.debug-vnc.yml 临时开启
ENABLE_VNC=0

# 如果临时启用 noVNC，可按需改为 127.0.0.1 或内网地址
NOVNC_BIND_IP=127.0.0.1
NOVNC_PUBLISH_PORT=6080

# ── Docker / 通用运行参数 ───────────────────────────────────
# 本地 SQLite（默认，无需配置）
# APP_DATABASE_URL=data/database.db

# 远程 PostgreSQL（优先）
# APP_DATABASE_URL=postgresql://user:password@host:5432/dbname

# 调试模式（生产建议保持 0）
# DEBUG=0

# 日志级别
# LOG_LEVEL=info

# 时区
# TZ=Asia/Shanghai

# ── Web UI 监听地址 ──────────────────────────────────────────
# 监听主机（适用于直接执行 python webui.py，默认 0.0.0.0）
# APP_HOST=0.0.0.0

# 监听端口（适用于直接执行 python webui.py，默认 8000）
# APP_PORT=8000

# Web UI 访问密钥（适用于直接执行 python webui.py）
# APP_ACCESS_PASSWORD=your_secret_password

# ── 第三方自动绑卡（可选） ───────────────────────────────────
# 第三方绑卡 API 地址（支持填 Workers 根域名，后端会自动补全路径）
# BIND_CARD_API_URL=https://twilight-river-f148.482091502.workers.dev/

# 第三方绑卡 API Key（可留空，后端会先尝试无鉴权）
# BIND_CARD_API_KEY=your_api_key_here

# ── 卡商 EFun（aimizy bindcard）接口版（可选） ───────────────
# vendor_efun 模式接口地址（默认 https://card.aimizy.com/api/v1/bindcard）
# VENDOR_BINDCARD_API_URL=https://card.aimizy.com/api/v1/bindcard

# vendor_efun 模式接口 Bearer Token
# VENDOR_BINDCARD_API_KEY=your_vendor_api_key_here
