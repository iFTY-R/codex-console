services:
  webui:
    build:
      context: .
    image: codex-console:local
    container_name: codex-console
    init: true
    shm_size: ${WEBUI_SHM_SIZE:-1gb}
    ports:
      - "${WEBUI_BIND_IP:-127.0.0.1}:${WEBUI_PUBLISH_PORT:-1455}:1455"
    environment:
      WEBUI_HOST: "0.0.0.0"
      WEBUI_PORT: "1455"
      WEBUI_ACCESS_PASSWORD: "${WEBUI_ACCESS_PASSWORD:?Set WEBUI_ACCESS_PASSWORD in .env before starting Docker Compose}"
      DISPLAY: ":99"
      ENABLE_VNC: "${ENABLE_VNC:-0}"
      VNC_PORT: "5900"
      NOVNC_PORT: "6080"
      DEBUG: "${DEBUG:-0}"
      LOG_LEVEL: "${LOG_LEVEL:-info}"
    volumes:
      - ./data:/app/data
      - ./logs:/app/logs
    healthcheck:
      test:
        - CMD-SHELL
        - python -c "import sys,urllib.request; r=urllib.request.urlopen('http://127.0.0.1:1455/login', timeout=5); sys.exit(0 if getattr(r, 'status', 200) < 500 else 1)"
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    restart: unless-stopped
    stop_grace_period: 30s
